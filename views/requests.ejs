<!DOCTYPE html>
<html lang="en">
<head>
    <title>Friend Requests</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { background:#f4f4f4; font-family:'Nunito',sans-serif; margin:0; }

        .page-wrap { max-width: 600px; margin: 40px auto; padding: 0 16px; }

        h2 {
            font-size: 1.3rem;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 24px;
        }

        .request-card {
            background: #fff;
            border-radius: 12px;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 14px;
            box-shadow: 0 2px 10px rgba(0,0,0,.06);
        }

        .request-card img {
            width: 52px; height: 52px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #ede9fe;
        }

        .req-info { flex: 1; }
        .req-info strong { display: block; font-size: 0.97rem; color: #1f2937; }
        .req-info span   { font-size: 0.8rem; color: #6b7280; }

        .req-actions { display: flex; gap: 8px; }

        .btn-accept {
            background: #7c3aed; color: #fff;
            border: none; padding: 7px 18px;
            border-radius: 7px; font-size: 0.82rem; font-weight: 700;
            font-family: 'Nunito', sans-serif; cursor: pointer;
            transition: background .2s;
        }
        .btn-accept:hover { background: #6d28d9; }

        .btn-reject {
            background: #fff; color: #6b7280;
            border: 1.5px solid #e5e7eb; padding: 7px 14px;
            border-radius: 7px; font-size: 0.82rem; font-weight: 700;
            font-family: 'Nunito', sans-serif; cursor: pointer;
            transition: border-color .2s, color .2s;
        }
        .btn-reject:hover { border-color: #ef4444; color: #ef4444; }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #9ca3af;
        }
        .empty-state span { font-size: 2.5rem; display: block; margin-bottom: 12px; }
        .empty-state p { font-size: 0.95rem; }
    </style>
</head>
<body>

<%- include("partials/navbar") %>

<div class="page-wrap">

    <h2>🔔 Friend Requests <% if(requests.length > 0){ %><span style="background:#7c3aed;color:#fff;font-size:0.75rem;padding:2px 9px;border-radius:99px;vertical-align:middle;"><%= requests.length %></span><% } %></h2>

    <% if(requests.length === 0){ %>
        <div class="empty-state">
            <span>🤝</span>
            <p>No pending friend requests right now.</p>
        </div>
    <% } else { %>

        <% requests.forEach(function(sender){ %>
        <div class="request-card">

            <img src="<%= sender.profilePhoto %>" alt="avatar">

            <div class="req-info">
                <strong><%= sender.username || sender.name %></strong>
                <span><%= sender.email %></span>
            </div>

            <div class="req-actions">

                <!-- Accept -->
                <form action="/acceptRequest/<%= sender._id %>" method="POST">
                    <button class="btn-accept" type="submit">✅ Accept</button>
                </form>

                <!-- Reject -->
                <form action="/rejectRequest/<%= sender._id %>" method="POST">
                    <button class="btn-reject" type="submit">✕ Reject</button>
                </form>

            </div>
        </div>
        <% }) %>

    <% } %>

</div>

</body>
</html>
