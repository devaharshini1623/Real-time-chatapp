<%- include("partials/navbar") %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', sans-serif;
    background: #f5f5f5;
    min-height: 100vh;
    color: #1a1a2e;
  }

  .search-page {
    max-width: 700px;
    margin: 0 auto;
    padding: 50px 24px 100px;
  }

  .search-heading {
    font-size: 2rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 6px;
  }

  .search-heading span { color: #6c3fcf; }

  .search-subtext {
    font-size: 0.9rem;
    color: #888;
    margin-bottom: 30px;
  }

  .search-form {
    display: flex;
    gap: 10px;
    margin-bottom: 36px;
  }

  .search-input {
    flex: 1;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 10px;
    padding: 13px 18px;
    font-size: 0.95rem;
    font-family: 'Inter', sans-serif;
    color: #1a1a2e;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .search-input::placeholder { color: #bbb; }

  .search-input:focus {
    border-color: #6c3fcf;
    box-shadow: 0 0 0 3px rgba(108, 63, 207, 0.12);
  }

  .search-btn {
    background: #6c3fcf;
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 13px 24px;
    font-size: 0.9rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  .search-btn:hover { background: #5a32b0; }

  .results-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #aaa;
    font-weight: 600;
    margin-bottom: 14px;
  }

  .user-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .user-card {
    background: #fff;
    border: 1px solid #ebebeb;
    border-radius: 14px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: box-shadow 0.2s;
    animation: fadeUp 0.3s ease both;
  }

  .user-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.07); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .user-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6c3fcf, #a855f7);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    color: #fff;
    flex-shrink: 0;
    overflow: hidden;
  }

  .user-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .user-name {
    font-weight: 600;
    font-size: 0.97rem;
    color: #1a1a2e;
  }

  .user-email {
    font-size: 0.8rem;
    color: #aaa;
    margin-top: 2px;
  }

  /* ADD FRIEND button */
  .btn-add {
    background: #6c3fcf;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 9px 18px;
    font-size: 0.82rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .btn-add:hover { background: #5a32b0; }

  /* REQUESTED button */
  .btn-requested {
    background: #fff;
    color: #6c3fcf;
    border: 1.5px solid #6c3fcf;
    border-radius: 8px;
    padding: 9px 18px;
    font-size: 0.82rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .btn-requested:hover {
    background: #fdf4ff;
    color: #c0392b;
    border-color: #c0392b;
  }

  .btn-requested:hover::after {
    content: ' ✕';
  }

  .no-results {
    text-align: center;
    padding: 60px 0;
    color: #ccc;
    font-size: 0.95rem;
  }

  .no-results-icon {
    font-size: 2.2rem;
    margin-bottom: 10px;
    display: block;
  }
</style>

<div class="search-page">
  <h1 class="search-heading">Find <span>People</span></h1>
  <p class="search-subtext">Search by name to connect with others.</p>

  <form class="search-form" method="GET" action="/search">
    <input class="search-input" type="text" name="q"
           placeholder="Search by name…"
           value="<%= typeof query !== 'undefined' ? query : '' %>"
           autocomplete="off">
    <button class="search-btn" type="submit">Search</button>
  </form>

  <% if (users && users.length > 0) { %>
    <p class="results-label"><%= users.length %> result<%= users.length !== 1 ? 's' : '' %> found</p>
    <ul class="user-list">
      <% users.forEach(u => { %>
        <li class="user-card">
          <div class="user-info">
            <div class="user-avatar">
              <% if (u.profilePhoto) { %>
                <img src="<%= u.profilePhoto %>" alt="<%= u.name %>">
              <% } else { %>
                <%= u.name.charAt(0).toUpperCase() %>
              <% } %>
            </div>
            <div>
              <div class="user-name"><%= u.name %></div>
              <div class="user-email"><%= u.email %></div>
            </div>
          </div>

          <%
            const isFriend   = currentUser.friends.map(f => f.toString()).includes(u._id.toString());
            const isRequested = u.friendRequests && u.friendRequests.map(r => r.toString()).includes(currentUser._id.toString());
          %>

          <% if (isFriend) { %>
            <span style="font-size:0.82rem;color:#27ae60;font-weight:600;">✓ Friends</span>

          <% } else if (isRequested) { %>
            <!-- Cancel request -->
            <form method="POST" action="/cancelRequest/<%= u._id %>">
              <button class="btn-requested" type="submit">Requested</button>
            </form>

          <% } else { %>
            <!-- Send request -->
            <form method="POST" action="/sendRequest/<%= u._id %>">
              <button class="btn-add" type="submit">+ Add Friend</button>
            </form>
          <% } %>

        </li>
      <% }) %>
    </ul>
  <% } else { %>
    <div class="no-results">
      <span class="no-results-icon">🔍</span>
      No users found. Try a different search.
    </div>
  <% } %>
</div>