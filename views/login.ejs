<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #f5f4fb;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    /* Subtle background blobs */
    body::before, body::after {
      content: '';
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.18;
      pointer-events: none;
      z-index: 0;
    }
    body::before {
      width: 420px; height: 420px;
      background: #7c3aed;
      top: -100px; left: -100px;
    }
    body::after {
      width: 320px; height: 320px;
      background: #a855f7;
      bottom: -80px; right: -80px;
    }

    .card {
      position: relative;
      z-index: 1;
      background: #fff;
      border: 1px solid #e8e4f5;
      border-radius: 20px;
      padding: 44px 40px 36px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 8px 40px rgba(108, 63, 207, 0.08);
      animation: rise 0.5s cubic-bezier(.22,.68,0,1.2) both;
    }

    @keyframes rise {
      from { opacity: 0; transform: translateY(24px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Logo / brand mark */
    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 32px;
    }

    .brand-icon {
      width: 40px; height: 40px;
      background: linear-gradient(135deg, #7c3aed, #a855f7);
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem;
    }

    .brand-name {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.25rem;
      color: #1a1a2e;
      letter-spacing: -0.02em;
    }

    .heading {
      font-family: 'Syne', sans-serif;
      font-size: 1.75rem;
      font-weight: 800;
      color: #1a1a2e;
      letter-spacing: -0.03em;
      line-height: 1.15;
      margin-bottom: 6px;
    }

    .subtext {
      font-size: 0.88rem;
      color: #9b97b2;
      font-weight: 400;
      margin-bottom: 32px;
    }

    .field {
      margin-bottom: 16px;
    }

    label {
      display: block;
      font-size: 0.78rem;
      font-weight: 600;
      color: #6b6880;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 7px;
    }

    input[type="email"],
    input[type="password"] {
      width: 100%;
      background: #f9f8ff;
      border: 1.5px solid #e3dff5;
      border-radius: 11px;
      padding: 13px 16px;
      font-size: 0.95rem;
      font-family: 'DM Sans', sans-serif;
      color: #1a1a2e;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }

    input::placeholder { color: #c4bfe0; }

    input:focus {
      background: #fff;
      border-color: #7c3aed;
      box-shadow: 0 0 0 3.5px rgba(124, 58, 237, 0.12);
    }

    .forgot {
      text-align: right;
      margin-top: -8px;
      margin-bottom: 24px;
    }

    .forgot a {
      font-size: 0.8rem;
      color: #9b97b2;
      text-decoration: none;
      transition: color 0.2s;
    }

    .forgot a:hover { color: #7c3aed; }

    .btn-login {
      width: 100%;
      background: linear-gradient(135deg, #7c3aed 0%, #9333ea 100%);
      color: #fff;
      border: none;
      border-radius: 11px;
      padding: 14px;
      font-size: 0.95rem;
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      letter-spacing: 0.02em;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 4px 18px rgba(124, 58, 237, 0.28);
    }

    .btn-login:hover {
      opacity: 0.92;
      transform: translateY(-1px);
      box-shadow: 0 6px 24px rgba(124, 58, 237, 0.36);
    }

    .btn-login:active { transform: translateY(0); }

    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 28px 0 24px;
      color: #d4d0e8;
      font-size: 0.8rem;
    }

    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #ece9f8;
    }

    .signup-cta {
      text-align: center;
      font-size: 0.88rem;
      color: #9b97b2;
    }

    .signup-cta a {
      color: #7c3aed;
      font-weight: 600;
      text-decoration: none;
      transition: color 0.2s;
    }

    .signup-cta a:hover {
      color: #6d28d9;
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="card">

    <div class="brand">
      <div class="brand-icon">💬</div>
      <span class="brand-name">Name</span>
    </div>

    <h1 class="heading">Welcome back</h1>
    <p class="subtext">Sign in to continue chatting.</p>

    <form action="/auth/login" method="POST">

      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required>
      </div>

      <div class="field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required>
      </div>

      <div class="forgot">
        <a href="#">Forgot password?</a>
      </div>

      <button class="btn-login" type="submit">Sign In</button>
    </form>

    <div class="divider">or</div>

    <p class="signup-cta">
      Don't have an account? <a href="/register">Create one</a>
    </p>

  </div>
</body>
</html>